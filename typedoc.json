{
  "entryPointStrategy": "packages",
  "tsconfig": "tsconfig.typedoc.json",
  "entryPoints": ["packages/*"],
  "out": "docs",
  "name": "Quatrain Core Documentation",
  "readme": "README.md",
  "excludePrivate": true,
  "excludeInternal": true,
  "githubPages": true,
  "cleanOutputDir": true,
  "customCss": "typedoc-theme.css",
  "hideGenerator": true,
  "searchInComments": true,
  "projectDocuments": ["packages/*/README.md", "packages/*/HOWTO.md"]
}
