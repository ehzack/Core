FROM node:22-alpine AS builder

# Enable Corepack for Yarn
RUN corepack enable

# Install bun globally for workspaces that require it during build
RUN npm install -g bun

WORKDIR /app

# Copy the entire monorepo
COPY . .

# Install dependencies
RUN yarn install

# Build ONLY what is needed for the studio image (this skips api-gateway entirely)
RUN npx turbo run build --filter=@quatrain/studio-image...

# Final image
FROM oven/bun:alpine

WORKDIR /app

# Copy the built monorepo
COPY --from=builder /app /app

# Set environment
ENV PORT=4000
EXPOSE 4000

# Start Studio API (which now also serves Studio Web)
WORKDIR /app/apps/studio-api
CMD ["bun", "run", "start"]
