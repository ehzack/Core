# Stage 1: Builder
FROM node:22-alpine AS builder

# Set working directory
WORKDIR /app

# Copy the monorepo configuration files for dependency installation
COPY package.json yarn.lock turbo.json ./
COPY .yarn ./.yarn

# Copy the source code for the entire monorepo to ensure the script has access
# to all packages, apps, and containers for documentation extraction.
COPY . .

# Enable corepack first so we use Yarn Berry
RUN corepack enable

# Switch to node-modules linker for maximum compatibility with TypeDoc's internal TS compiler
RUN yarn config set nodeLinker node-modules

# Install dependencies using Yarn
RUN yarn install --immutable

# Run the aggregation script (generates API ref and copies Markdown files)
# We use ts-node (which is in the root package.json) to execute the TypeScript file directly
RUN yarn ts-node scripts/build-docs.ts

# Build the static Next.js documentation
WORKDIR /app/docs
RUN touch yarn.lock
RUN yarn install
# Increase Node.js memory limit to 8GB to prevent OOM during Nextra MDX compilation
ENV NODE_OPTIONS="--max-old-space-size=8192"
RUN yarn build

# Stage 2: Runner
FROM nginx:alpine AS runner

# Remove default nginx static assets
RUN rm -rf /usr/share/nginx/html/*

# Copy the static Next.js export from the builder stage
# (Assuming Next.js output is set to 'export' which generates the /out folder)
COPY --from=builder /app/docs/out /usr/share/nginx/html

# Copy custom Nginx configuration for Next.js static routing
COPY docs/nginx.conf /etc/nginx/conf.d/default.conf

# Expose port 80
EXPOSE 80

# Start Nginx
CMD ["nginx", "-g", "daemon off;"]
