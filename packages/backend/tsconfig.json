{
   "extends": "@tsconfig/recommended/tsconfig.json",
   "compileOnSave": true,
   "compilerOptions": {
      "rootDir": "src",
      "outDir": "dist",
      "declaration": true,
      "target": "es6",
      "resolveJsonModule": true,
      "strict": true,
      "types": ["node"],
      "lib": ["es6", "dom"]
   },
   "include": ["src"],
   "exclude": ["node_modules", "**/__test__", "**/*.spec.ts", "**/*.test.ts"]
}
